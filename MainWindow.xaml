<ui:FluentWindow x:Class="ScrcpyGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:ScrcpyGui.ViewModels"
        Title="Scrcpy GUI UWP" Width="1200" Height="890"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ExtendsContentIntoTitleBar="True"
        Icon="Assets/app_icon.ico"
        WindowBackdropType="Mica">

    <ui:FluentWindow.DataContext>
        <vm:MainViewModel />
    </ui:FluentWindow.DataContext>

    <Grid>
        <ui:TitleBar Title="Scrcpy GUI UWP" ShowMaximize="True" ShowMinimize="True" Icon="Assets/app_icon.png" />

        <!-- Main content below titlebar -->
        <Grid Margin="0,36,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ════════════════════════════════════════════════════ -->
            <!-- LEFT SIDEBAR: Device Hub + Start Button             -->
            <!-- ════════════════════════════════════════════════════ -->
            <Border Grid.Column="0" BorderThickness="0,0,1,0"
                    BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16,8,16,16">

                            <!-- App Title + Theme Toggle -->
                            <Grid Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="ScrcpyGUI" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}" FontSize="11"
                                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <ui:Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                           Click="ToggleTheme_Click" Padding="6" 
                                           ToolTip="Toggle Light/Dark Theme"
                                           Icon="{ui:SymbolIcon WeatherSunny24}" x:Name="ThemeToggleBtn" />
                            </Grid>

                            <!-- Scrcpy Engine Status -->
                            <ui:CardControl Margin="0,0,0,12">
                                <ui:CardControl.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Symbol="Desktop24" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Scrcpy Engine" FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Text="{Binding ScrcpyStatusMessage}" FontSize="11"
                                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:Button Icon="{ui:SymbolIcon ArrowDownload24}" ToolTip="Download scrcpy"
                                                       Click="DownloadScrcpy_Click" Appearance="Primary" Padding="6"
                                                       Visibility="{Binding ScrcpyFound, Converter={StaticResource InverseBoolToVisConverter}}" />
                                            <ui:Button Icon="{ui:SymbolIcon FolderOpen24}" ToolTip="Set custom path"
                                                       Click="SetPath_Click" Padding="6" Margin="4,0,0,0" />
                                            <ui:Button Icon="{ui:SymbolIcon ArrowReset24}" ToolTip="Reset path"
                                                       Click="ResetPath_Click" Padding="6" Margin="4,0,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </ui:CardControl.Header>
                            </ui:CardControl>

                            <ProgressBar Value="{Binding DownloadProgress}" Maximum="100" Margin="0,0,0,8"
                                         Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisConverter}}" />

                            <!-- ── DEVICE HUB ── -->
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Device Hub" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}"
                                               Click="RefreshDevices_Click" Padding="8,4" FontSize="11"
                                               IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBoolConverter}}" />
                                    <ui:Button Content="Kill ADB" Appearance="Danger" Click="KillAdb_Click"
                                               Margin="4,0,0,0" FontSize="11" Padding="8,4" />
                                </StackPanel>
                            </Grid>

                            <!-- Device List -->
                            <ListBox ItemsSource="{Binding Devices}" SelectedItem="{Binding ActiveDevice, Mode=TwoWay}"
                                     Background="Transparent" BorderThickness="0" MinHeight="30" MaxHeight="180"
                                     x:Name="DeviceListBox" Margin="0,0,0,8">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Symbol="Phone24" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding}" FontSize="12" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- USB / Wireless Tabs -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:Button x:Name="TabUsbBtn" Content="USB" Icon="{ui:SymbolIcon UsbPlug20}"
                                           HorizontalAlignment="Stretch" Click="TabUsb_Click"
                                           Appearance="Primary" Margin="0,0,2,0" />
                                <ui:Button x:Name="TabWirelessBtn" Content="Wireless" Icon="{ui:SymbolIcon Wifi124}"
                                           Grid.Column="1" HorizontalAlignment="Stretch" Click="TabWireless_Click"
                                           Appearance="Secondary" Margin="2,0,0,0" />
                            </Grid>

                            <!-- USB Panel -->
                            <StackPanel x:Name="UsbPanel" Margin="0,0,0,8">
                                <Border CornerRadius="8" Padding="12" Margin="0,0,0,4"
                                        Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="USB Setup" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6" />
                                        <TextBlock TextWrapping="Wrap" FontSize="11"
                                                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}">
                                            Enable <Bold>Developer Options</Bold> and <Bold>USB Debugging</Bold> on your phone, 
                                            then connect via USB cable. Hit Refresh to detect.
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Wireless Panel -->
                            <StackPanel x:Name="WirelessPanel" Visibility="Collapsed" Margin="0,0,0,8">
                                <!-- Wireless Tip -->
                                <Border CornerRadius="8" Padding="12" Margin="0,0,0,8"
                                        Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}">
                                        Connect device to <Bold>Same Wi-Fi</Bold> and enable <Bold>Wireless Debugging</Bold> in Developer Options.
                                    </TextBlock>
                                </Border>

                                <!-- IP Connect -->
                                <TextBlock Text="IP Connect" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox x:Name="ConnectIpBox" PlaceholderText="192.168.x.x:5555" />
                                    <ui:Button Grid.Column="1" Content="Connect" Appearance="Primary"
                                               Margin="6,0,0,0" Click="ConnectDevice_Click" Padding="12,6" />
                                </Grid>

                                <!-- Auto-Connect Toggle -->
                                <CheckBox Content="Auto-connect on discovery" x:Name="ChkAutoConnect"
                                          IsChecked="{Binding IsAutoConnect, Mode=TwoWay}" Margin="0,0,0,8" FontSize="11" />

                                <!-- Recent Devices -->
                                <StackPanel Visibility="{Binding HistoryDevices.Count, Converter={StaticResource CountToVisConverter}}">
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="Recent Devices" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                        <ui:Button Content="Clear" HorizontalAlignment="Right" FontSize="10"
                                                   Padding="6,2" Click="ClearHistory_Click" Appearance="Secondary" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding HistoryDevices}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ui:Button HorizontalAlignment="Stretch" Appearance="Secondary"
                                                           Content="{Binding}" FontSize="11" Padding="8,4" Margin="0,2"
                                                           Click="HistoryDevice_Click" HorizontalContentAlignment="Left" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Pair Device -->
                                <Separator Margin="0,8,0,8" />
                                <TextBlock Text="Pair Device (Android 11+)" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox x:Name="PairIpBox" PlaceholderText="IP:Port" Margin="0,0,4,0" />
                                    <ui:TextBox x:Name="PairCodeBox" PlaceholderText="Pairing Code" Grid.Column="1" Margin="4,0,0,0" />
                                </Grid>
                                <ui:Button Content="Start Pairing" Appearance="Primary" HorizontalAlignment="Stretch"
                                           Click="PairDevice_Click" />
                            </StackPanel>

                            <!-- Keyboard Shortcuts (moved to sidebar) -->
                            <ui:CardExpander Header="Keyboard Shortcuts" Icon="{ui:SymbolIcon Info24}" IsExpanded="False"
                                             Margin="0,0,0,8">
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition /><RowDefinition /><RowDefinition />
                                        <RowDefinition /><RowDefinition /><RowDefinition />
                                    </Grid.RowDefinitions>
                                    
                                    <ui:SymbolIcon Grid.Row="0" Symbol="FullScreenMaximize24" FontSize="14" Margin="0,2,6,2" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Toggle fullscreen" FontSize="11" Margin="0,2" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="MOD + F" FontSize="11" FontFamily="Consolas" Margin="0,2" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                    
                                    <ui:SymbolIcon Grid.Row="1" Symbol="ArrowExpand24" FontSize="14" Margin="0,2,6,2" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Resize 1:1" FontSize="11" Margin="0,2" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="MOD + G" FontSize="11" FontFamily="Consolas" Margin="0,2" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                    
                                    <ui:SymbolIcon Grid.Row="2" Symbol="Home24" FontSize="14" Margin="0,2,6,2" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Home button" FontSize="11" Margin="0,2" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="MOD + H" FontSize="11" FontFamily="Consolas" Margin="0,2" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                    
                                    <ui:SymbolIcon Grid.Row="3" Symbol="ArrowLeft24" FontSize="14" Margin="0,2,6,2" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Back button" FontSize="11" Margin="0,2" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="MOD + B" FontSize="11" FontFamily="Consolas" Margin="0,2" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                    
                                    <ui:SymbolIcon Grid.Row="4" Symbol="Power24" FontSize="14" Margin="0,2,6,2" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="Power" FontSize="11" Margin="0,2" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="4" Grid.Column="2" Text="MOD + P" FontSize="11" FontFamily="Consolas" Margin="0,2" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                    
                                    <ui:SymbolIcon Grid.Row="5" Symbol="PhoneDesktop24" FontSize="14" Margin="0,2,6,2" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="Turn screen off" FontSize="11" Margin="0,2" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="5" Grid.Column="2" Text="MOD + O" FontSize="11" FontFamily="Consolas" Margin="0,2" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </ui:CardExpander>

                            <!-- File Push -->
                            <Border CornerRadius="8" Padding="16,12" Cursor="Hand"
                                    Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1,1,1,1"
                                    MouseDown="FilePush_Click" AllowDrop="True" Drop="FileDrop_Handler">
                                <StackPanel HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                    <TextBlock Text="Push Files / Install APK" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    <TextBlock Text="Click to browse or drag &amp; drop" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Start / Stop Button (pinned at bottom of sidebar) -->
                    <Border Grid.Row="1" Padding="16,8,16,12"
                            BorderThickness="0,1,0,0" BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}">
                        <Grid>
                            <ui:Button x:Name="BtnStart" Click="StartSession_Click" Appearance="Primary"
                                       HorizontalAlignment="Stretch" Padding="0,14"
                                       HorizontalContentAlignment="Center" Icon="{ui:SymbolIcon Play24}">
                                <TextBlock Text="Start Session" FontWeight="SemiBold" FontSize="14" />
                            </ui:Button>
                            <ui:Button x:Name="BtnStop" Click="StopSession_Click" Appearance="Danger"
                                       HorizontalAlignment="Stretch" Padding="0,14"
                                       Visibility="Collapsed" HorizontalContentAlignment="Center" Icon="{ui:SymbolIcon Stop24}">
                                <TextBlock Text="Stop Session" FontWeight="SemiBold" FontSize="14" />
                            </ui:Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════════════════ -->
            <!-- RIGHT PANEL: Config + Behavior + Console            -->
            <!-- ════════════════════════════════════════════════════ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="24,12,24,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5*" />
                            <ColumnDefinition Width="4*" />
                        </Grid.ColumnDefinitions>

                        <!-- ═══ LEFT COLUMN (Sources & Config) ═══ -->
                        <Grid Grid.Column="0" Margin="0,0,12,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <!-- CAPTURE SOURCE -->
                                <TextBlock Text="Capture Source" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ui:Button x:Name="BtnMirror" Click="SessionMode_Click" Tag="mirror"
                                               Margin="0,0,4,0" HorizontalAlignment="Stretch" Padding="8,10"
                                               HorizontalContentAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Desktop24" FontSize="18" Margin="0,0,8,0" />
                                            <TextBlock Text="Screen" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </ui:Button>
                                    <ui:Button x:Name="BtnCamera" Click="SessionMode_Click" Tag="camera"
                                               Grid.Column="1" Margin="4,0,4,0" HorizontalAlignment="Stretch" Padding="8,10"
                                               HorizontalContentAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Camera24" FontSize="18" Margin="0,0,8,0" />
                                            <TextBlock Text="Camera" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </ui:Button>
                                    <ui:Button x:Name="BtnDesktop" Click="SessionMode_Click" Tag="desktop"
                                               Grid.Column="2" Margin="4,0,0,0" HorizontalAlignment="Stretch" Padding="8,10"
                                               HorizontalContentAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Grid24" FontSize="18" Margin="0,0,8,0" />
                                            <TextBlock Text="Desktop" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </ui:Button>
                                </Grid>

                            </StackPanel>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,4">
                                <StackPanel Margin="0,0,16,0">

                                    <!-- MIRROR MODE: HID Input -->
                                    <StackPanel x:Name="HidPanel" Margin="0,0,0,8">
                                        <ui:CardExpander Header="Input Enhancements (HID)" Icon="{ui:SymbolIcon Keyboard24}" IsExpanded="False">
                                            <StackPanel Margin="0,8,0,0">
                                                <TextBlock Text="Control your phone using your PC's keyboard and mouse." FontSize="11"
                                                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" TextWrapping="Wrap" />
                                                <CheckBox Content="HID Keyboard — Physical keyboard passthrough" x:Name="ChkHidKeyboard"
                                                          Checked="HidKeyboard_Changed" Unchecked="HidKeyboard_Changed" Margin="0,0,0,4" FontSize="12" />
                                                <CheckBox Content="HID Mouse — Physical mouse passthrough" x:Name="ChkHidMouse"
                                                          Checked="HidMouse_Changed" Unchecked="HidMouse_Changed" Margin="0,0,0,4" FontSize="12" />
                                                <CheckBox Content="Pure OTG Mode — Input only, no mirroring" x:Name="ChkOtgPure"
                                                          Checked="OtgPure_Changed" Unchecked="OtgPure_Changed" Margin="0,0,0,0" FontSize="12" />
                                            </StackPanel>
                                        </ui:CardExpander>
                                    </StackPanel>

                                    <!-- CAMERA MODE OPTIONS -->
                                    <StackPanel x:Name="CameraPanel" Visibility="Collapsed" Margin="0,0,0,8">
                                        <ui:CardExpander Header="Camera Settings" Icon="{ui:SymbolIcon Camera24}" IsExpanded="True">
                                            <StackPanel Margin="0,8,0,0">
                                                <!-- Webcam Tip -->
                                                <Border CornerRadius="6" Padding="10" Margin="0,0,0,12"
                                                        Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                        BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}">
                                                        💡 <Bold>Webcam Tip:</Bold> Use your phone as a webcam by capturing this window in OBS Studio.
                                                    </TextBlock>
                                                </Border>

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Margin="0,0,4,0">
                                                        <TextBlock Text="Camera Facing" FontSize="12" Margin="0,0,0,4" />
                                                        <ComboBox x:Name="CameraFacingCombo" SelectedIndex="0" SelectionChanged="CameraFacing_Changed"
                                                                  HorizontalAlignment="Stretch">
                                                            <ComboBoxItem Content="Back" Tag="back" />
                                                            <ComboBoxItem Content="Front" Tag="front" />
                                                            <ComboBoxItem Content="External" Tag="external" />
                                                        </ComboBox>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                                        <Grid Margin="0,0,0,4">
                                                            <TextBlock Text="Camera Device" FontSize="12" />
                                                            <ui:Button Content="Scan Lenses" HorizontalAlignment="Right" FontSize="10"
                                                                       Padding="6,2" Click="ListCameras_Click" Appearance="Primary" />
                                                        </Grid>
                                                        <ComboBox x:Name="CameraIdCombo" SelectedIndex="0" SelectionChanged="CameraId_Changed"
                                                                  HorizontalAlignment="Stretch">
                                                            <ComboBoxItem Content="Auto Select" Tag="" />
                                                        </ComboBox>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Margin="0,0,4,0">
                                                        <TextBlock Text="Aspect Ratio" FontSize="12" Margin="0,0,0,4" />
                                                        <ComboBox x:Name="CameraArCombo" SelectedIndex="0" SelectionChanged="CameraAr_Changed"
                                                                  HorizontalAlignment="Stretch">
                                                            <ComboBoxItem Content="Default" Tag="0" />
                                                            <ComboBoxItem Content="16:9" Tag="16:9" />
                                                            <ComboBoxItem Content="4:3" Tag="4:3" />
                                                        </ComboBox>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                                        <TextBlock Text=" " FontSize="12" Margin="0,0,0,4" />
                                                        <CheckBox Content="High Speed Mode" x:Name="ChkCameraHighSpeed"
                                                                  Checked="CameraHighSpeed_Changed" Unchecked="CameraHighSpeed_Changed" FontSize="12" />
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </ui:CardExpander>
                                    </StackPanel>

                                    <!-- DESKTOP MODE OPTIONS -->
                                    <StackPanel x:Name="DesktopPanel" Visibility="Collapsed" Margin="0,0,0,8">
                                        <ui:CardExpander Header="Virtual Display Engine" Icon="{ui:SymbolIcon Grid24}" IsExpanded="True">
                                            <StackPanel Margin="0,8,0,0">
                                                <!-- Presets -->
                                                <TextBlock Text="Quick Presets" FontSize="12" Margin="0,0,0,4" />
                                                <ComboBox x:Name="VdPresetCombo" SelectedIndex="0" SelectionChanged="VdPreset_Changed"
                                                          HorizontalAlignment="Stretch" Margin="0,0,0,10">
                                                    <ComboBoxItem Content="1080p Standard (1920×1080)" Tag="1080p" />
                                                    <ComboBoxItem Content="1440p High (2560×1440)" Tag="1440p" />
                                                    <ComboBoxItem Content="4K Ultra (3840×2160)" Tag="4k" />
                                                    <ComboBoxItem Content="Ultra-Wide 21:9 (2560×1080)" Tag="ultrawide" />
                                                </ComboBox>

                                                <!-- Width -->
                                                <TextBlock FontSize="12" Margin="0,0,0,2">
                                                    <Run Text="Width: " />
                                                    <Run Text="" x:Name="VdWidthLabel" FontWeight="SemiBold" />
                                                </TextBlock>
                                                <Slider Minimum="480" Maximum="3840" Value="1920" x:Name="VdWidthSlider"
                                                        ValueChanged="VdWidth_Changed" TickFrequency="10" IsSnapToTickEnabled="True" IsMoveToPointEnabled="True"
                                                        Margin="0,0,0,8" />

                                                <!-- Height -->
                                                <TextBlock FontSize="12" Margin="0,0,0,2">
                                                    <Run Text="Height: " />
                                                    <Run Text="" x:Name="VdHeightLabel" FontWeight="SemiBold" />
                                                </TextBlock>
                                                <Slider Minimum="360" Maximum="2160" Value="1080" x:Name="VdHeightSlider"
                                                        ValueChanged="VdHeight_Changed" TickFrequency="10" IsSnapToTickEnabled="True" IsMoveToPointEnabled="True"
                                                        Margin="0,0,0,8" />

                                                <!-- DPI -->
                                                <TextBlock FontSize="12" Margin="0,0,0,2">
                                                    <Run Text="DPI: " />
                                                    <Run Text="" x:Name="VdDpiLabel" FontWeight="SemiBold" />
                                                </TextBlock>
                                                <Slider Minimum="120" Maximum="640" Value="420" x:Name="VdDpiSlider"
                                                        ValueChanged="VdDpi_Changed" TickFrequency="10" IsSnapToTickEnabled="True" IsMoveToPointEnabled="True" />

                                                <CheckBox Content="Lock Aspect Ratio" x:Name="ChkAspectRatioLock" 
                                                          IsChecked="{Binding Config.AspectRatioLock, Mode=TwoWay}" Margin="0,8,0,0" FontSize="12" />
                                            </StackPanel>
                                        </ui:CardExpander>
                                    </StackPanel>

                                    <!-- ENGINE CONFIGURATION -->
                                    <ui:CardExpander Header="Engine Configuration" Icon="{ui:SymbolIcon VideoClip24}" IsExpanded="True"
                                                     x:Name="EngineConfigPanel">
                                        <StackPanel Margin="0,8,0,0">
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,4,8">
                                                    <TextBlock Text="Resolution" FontSize="12" Margin="0,0,0,4" />
                                                    <ComboBox x:Name="ResolutionCombo" SelectedIndex="0" SelectionChanged="Resolution_Changed"
                                                              HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="Original" Tag="0" />
                                                        <ComboBoxItem Content="4K (3840)" Tag="3840" />
                                                        <ComboBoxItem Content="2K (2560)" Tag="2560" />
                                                        <ComboBoxItem Content="1080p" Tag="1920" />
                                                        <ComboBoxItem Content="720p" Tag="1280" />
                                                        <ComboBoxItem Content="480p" Tag="800" />
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Grid.Row="0" Margin="4,0,0,8">
                                                    <TextBlock Text="Max FPS" FontSize="12" Margin="0,0,0,4" />
                                                    <ComboBox x:Name="FpsCombo" SelectedIndex="1" SelectionChanged="Fps_Changed"
                                                              HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="30" Tag="30" />
                                                        <ComboBoxItem Content="60" Tag="60" />
                                                        <ComboBoxItem Content="90" Tag="90" />
                                                        <ComboBoxItem Content="120" Tag="120" />
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,4,0">
                                                    <TextBlock Text="Rotation" FontSize="12" Margin="0,0,0,4" />
                                                    <ComboBox x:Name="RotationCombo" SelectedIndex="0" SelectionChanged="Rotation_Changed"
                                                              HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="0°" Tag="0" />
                                                        <ComboBoxItem Content="-90°" Tag="270" />
                                                        <ComboBoxItem Content="+90°" Tag="90" />
                                                        <ComboBoxItem Content="180°" Tag="180" />
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Grid.Row="1" Margin="4,0,0,0">
                                                    <TextBlock Text="Video Codec" FontSize="12" Margin="0,0,0,4" />
                                                    <ComboBox x:Name="CodecCombo" SelectedIndex="0" SelectionChanged="Codec_Changed"
                                                              HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="H.264 (Default)" Tag="h264" />
                                                        <ComboBoxItem Content="H.265 (HEVC)" Tag="h265" />
                                                        <ComboBoxItem Content="AV1" Tag="av1" />
                                                    </ComboBox>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock FontSize="12" Margin="0,0,0,2">
                                                <Run Text="Bitrate: " />
                                                <Run Text="" x:Name="BitrateLabel" FontWeight="SemiBold" />
                                            </TextBlock>
                                            <Slider Minimum="1" Maximum="50" Value="8" x:Name="BitrateSlider"
                                                    ValueChanged="Bitrate_Changed" TickFrequency="1" IsSnapToTickEnabled="True" IsMoveToPointEnabled="True" />
                                        </StackPanel>
                                    </ui:CardExpander>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- ═══ RIGHT COLUMN (Session Behavior) ═══ -->
                        <Grid Grid.Column="1" Margin="12,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Preferences" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,4">
                                <StackPanel Margin="0,0,16,0">
                                    <ui:CardExpander Header="Session Behavior" Icon="{ui:SymbolIcon Settings24}" IsExpanded="True" Margin="0,0,0,8">
                                        <StackPanel Margin="0,8,0,0">
                                            <CheckBox Content="Stay Awake — Keep device awake while mirroring" x:Name="ChkStayAwake"
                                                  Checked="SessionToggle_Changed" Unchecked="SessionToggle_Changed" Margin="0,0,0,8" FontSize="12" />
                                        <CheckBox Content="Screen Off — Turn off device screen to save battery" x:Name="ChkScreenOff"
                                                  Checked="SessionToggle_Changed" Unchecked="SessionToggle_Changed" Margin="0,0,0,8" FontSize="12" />
                                        <CheckBox Content="Forward Audio — Stream device audio to PC" x:Name="ChkAudio" IsChecked="True"
                                                  Checked="SessionToggle_Changed" Unchecked="SessionToggle_Changed" Margin="0,0,0,8" FontSize="12" />
                                        <CheckBox Content="Always On Top — Keep scrcpy window above others" x:Name="ChkAlwaysOnTop"
                                                  Checked="SessionToggle_Changed" Unchecked="SessionToggle_Changed" Margin="0,0,0,8" FontSize="12" />
                                        <CheckBox Content="Full Screen — Launch in fullscreen mode" x:Name="ChkFullscreen"
                                                  Checked="SessionToggle_Changed" Unchecked="SessionToggle_Changed" Margin="0,0,0,8" FontSize="12" />
                                        <CheckBox Content="Borderless — Launch without window borders" x:Name="ChkBorderless"
                                                  Checked="SessionToggle_Changed" Unchecked="SessionToggle_Changed" Margin="0,0,0,8" FontSize="12" />

                                        <Separator Margin="0,6,0,6" />

                                        <CheckBox Content="Record Feed — Save screen/camera recording" x:Name="ChkRecord"
                                                  Checked="SessionToggle_Changed" Unchecked="SessionToggle_Changed" Margin="0,0,0,8" FontSize="12" />
                                        <Grid Margin="24,0,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock VerticalAlignment="Center" FontSize="11" TextTrimming="CharacterEllipsis"
                                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4">
                                                <TextBlock.Text>
                                                    <Binding Path="Config.RecordPath" TargetNullValue="Default (Videos folder)"
                                                             FallbackValue="Default (Videos folder)" />
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <ui:Button Grid.Row="1" Content="Change Directory" Click="ChangeRecordPath_Click"
                                                       FontSize="11" Padding="8,4" HorizontalAlignment="Left" />
                                        </Grid>
                                    </StackPanel>
                                </ui:CardExpander>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>

                <!-- ═══ LOG PANEL (bottom) ═══ -->
                <Border Grid.Row="1" BorderThickness="0,1,0,0"
                        BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Height="200">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="16,8,16,4">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="WindowConsole20" FontSize="14" Margin="0,0,6,0" />
                                <TextBlock Text="Console" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ui:Button Content="Export" Icon="{ui:SymbolIcon ArrowDownload24}" Appearance="Secondary"
                                           FontSize="10" Padding="8,3" Click="ExportReport_Click" />
                                <ui:Button Content="Clear" Icon="{ui:SymbolIcon Delete24}" Appearance="Secondary"
                                           FontSize="10" Padding="8,3" Margin="4,0,0,0" Click="ClearLogs_Click" />
                            </StackPanel>
                        </Grid>

                        <ListBox Grid.Row="1" ItemsSource="{Binding Logs}" Background="Transparent" BorderThickness="0"
                                 x:Name="LogListBox" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 FontFamily="Cascadia Code, Cascadia Mono, Consolas, monospace" FontSize="11" Margin="8,0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="Margin" Value="0,-1,0,-1" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Padding="2,0" Margin="0"
                                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="2" Margin="16,4,16,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="$" FontWeight="Bold" FontSize="12" FontFamily="Consolas"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ui:TextBox Grid.Column="1" x:Name="TerminalInput"
                                        PlaceholderText="Enter command (e.g. adb devices, scrcpy --help)..."
                                        FontFamily="Cascadia Code, Consolas" FontSize="11" KeyDown="TerminalInput_KeyDown" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ════════════════════════════════════════════ -->
        <!-- ONBOARDING OVERLAY                           -->
        <!-- ════════════════════════════════════════════ -->
        <Grid x:Name="OnboardingOverlay" Visibility="{Binding IsOnboardingOpen, Converter={StaticResource BoolToVisConverter}}"
              Background="#80000000">
            <Border CornerRadius="12" MaxWidth="480" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="28"
                    Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Welcome to Scrcpy GUI UWP" FontSize="20" FontWeight="SemiBold" />
                        <ui:Button Icon="{ui:SymbolIcon Dismiss24}" HorizontalAlignment="Right"
                                   Click="CloseOnboarding_Click" Padding="4" />
                    </Grid>
                    <TextBlock Text="We need to set up some components before you can start mirroring your device."
                               FontSize="12" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,16" />

                    <ui:CardControl Margin="0,0,0,16">
                        <ui:CardControl.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="DesktopPulse24" FontSize="22" Margin="0,0,12,0" />
                                <StackPanel>
                                    <TextBlock Text="Scrcpy Engine" FontWeight="SemiBold" FontSize="12" />
                                    <TextBlock FontSize="11" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Not installed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ScrcpyFound}" Value="True">
                                                        <Setter Property="Text" Value="Ready to use!" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </ui:CardControl.Header>
                    </ui:CardControl>

                    <ui:Button Content="Download Scrcpy" Appearance="Primary" HorizontalAlignment="Stretch"
                               Padding="0,12" Click="DownloadScrcpy_Click" Margin="0,0,0,8"
                               Icon="{ui:SymbolIcon ArrowDownload24}" HorizontalContentAlignment="Center"
                               Visibility="{Binding ScrcpyFound, Converter={StaticResource InverseBoolToVisConverter}}"
                               IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBoolConverter}}" />

                    <ProgressBar Value="{Binding DownloadProgress}" Maximum="100" Margin="0,0,0,8"
                                 Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisConverter}}" />

                    <ui:Button Content="Continue" Appearance="Primary" HorizontalAlignment="Stretch"
                               Padding="0,12" Click="CompleteOnboarding_Click"
                               IsEnabled="{Binding ScrcpyFound}" HorizontalContentAlignment="Center"
                               Icon="{ui:SymbolIcon ArrowRight24}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
